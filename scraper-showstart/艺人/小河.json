        "content_html": "<p><img src=\"https://s2.showstart.com/img/2026/0206/13/30/a3d5c5645ce74d6ebacc809c69871f01_2164_10000_2753447.0x0.png?imageMogr2/thumbnail/640x/gravity/Center/crop/640x\" alt=\"\"></p>"
